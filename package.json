{
  "name": "appshelf",
  "version": "0.0.1",
  "private": true,
  "description": "A Windows desktop app for launching and managing localhost projects.",
  "license": "MIT",
  "keywords": [
    "electron",
    "localhost",
    "webapp",
    "launcher",
    "local-development"
  ],
  "main": "out/main/index.js",
  "scripts": {
